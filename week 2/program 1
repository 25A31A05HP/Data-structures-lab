#include <iostream>
using namespace std;

int main() {
    int n, arr[100]; // assuming max array size is 100
    cout << "enter n value";
    cin >> n;
    for (int i = 0; i < n; i++) {
        cout << "enter element " << i+1 << ": ";
        cin >> arr[i];
    }
    cout << "array elements are: ";
    for (int i = 0; i < n; i++) {
        cout << arr[i] << " ";
    }
    return 0;
}
