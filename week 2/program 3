include <iostream>
using namespace std;

int main() {
    int *arr, n, i;
    cout << "Enter total number of array elements ";
    cin >> n;
    arr = new int[n];
    for (i = 0; i < n; i++) {
        cin >> *(arr + i);
    }
    cout << "\nArray elements ";
    for (i = 0; i < n; i++) {
        cout << *(arr + i) << " ";
    }
    delete[] arr; // deleting memory
    return 0;
}
