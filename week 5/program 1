#include <iostream>
using namespace std;

class Addition {
private:
    int n;
    int *ptr;
    int sum;
public:
    void get_size() {
        cout << "Enter number of elements: ";
        cin >> n;
        ptr = new int[n];
    }
    
    void get_elements() {
        cout << "Enter " << n << " elements\n";
        for (int i = 0; i < n; i++) {
            cin >> ptr[i];
        }
    }
    
    void calculate_sum() {
        sum = 0;
        for (int i = 0; i < n; i++) {
            sum = sum + ptr[i];
        }
    }
    
    void display_sum() {
        cout << "Sum of elements: " << sum << endl;
        delete[] ptr;
    }
};

int main() {
    Addition obj;
    obj.get_size();
    obj.get_elements();
    obj.calculate_sum();
    obj.display_sum();
    return 0;
}
