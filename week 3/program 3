
#include <iostream>
using namespace std;

int main()
{
    int a[50], i, n, key;
    cout << "Enter n & key values";
    cin >> n >> key;
    for (i = 0; i < n; i++)
    {
        cout << "Enter array element" << i;
        cin >> a[i];
    }
    int low = 0, high = n - 1;
    while (low <= high)
    {
        int mid = (low + high) / 2;
        if (a[mid] == key)
        {
            cout << "Key found at location" << mid;
            break;
        }
        else if (a[mid] < key)
            low = mid + 1;
        else
            high = mid - 1;
    }
    return 0;
}
