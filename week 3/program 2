
#include <iostream>
using namespace std;

int main() {
    int i, n, key, arr[100], c = 0;
    cout << "Enter n & key: ";
    cin >> n >> key;
    cout << "\nEnter array element ";
    for (i = 0; i < n; i++) {
        cin >> arr[i];
        if (arr[i] == key)
            c++;
    }
    cout << "key repeated for " << c << " times";
    return 0;
}
