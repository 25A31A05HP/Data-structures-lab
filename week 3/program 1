
#include <iostream>
using namespace std;

int main()
{
    int n, i, key;
    bool flag;
    
    cout << "Enter n value & key value: ";
    cin >> n >> key;
    
    int a[n];
    
    cout << "Enter array elements";
    for (i = 0; i < n; i++)
    {
        cin >> a[i];
    }
    
    for (i = 0; i < n; i++)
    {
        if (key == a[i])
        {
            cout << "Key element found";
            flag = true;
            break;
        }
    }
    
    if (!flag)
    {
        cout << "Element not found";
    }
}
