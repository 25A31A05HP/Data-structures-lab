
#include <iostream>
using namespace std;

// Define the structure of a node
struct Node {
    int data;
    Node* next;
};

int main() {
    // Create first node
    Node* first = new Node();
    first->data = 10;
    first->next = NULL;

    // Create second node
    Node* second = new Node();
    second->data = 20;
    second->next = NULL;

    // Link first node to second node
    first->next = second;

    // Traverse and print the linked list
    Node* temp = first;
    while (temp != NULL) {
        cout << temp->data << " -> ";
        temp = temp->next;
    }
    cout << "NULL";

    return 0;
}
